# Adaptive Teaching AI System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# LLM Configuration
# ============================================================================

# LLM Provider: "openai" or "ollama" or "mock"
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=256

# Ollama Configuration (for local deployment)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mixtral:8x7b

# ============================================================================
# Behavioral Analysis Configuration
# ============================================================================

CONFIDENCE_FACE_DETECTION=0.5
CONFIDENCE_POSE_DETECTION=0.5
CONFIDENCE_HAND_DETECTION=0.5

SMILE_THRESHOLD=0.3
FROWN_THRESHOLD=0.3
FURROWED_BROW_THRESHOLD=0.4

LEAN_THRESHOLD=0.15
TENSION_THRESHOLD=0.7

PITCH_THRESHOLD_LOW=80
PITCH_THRESHOLD_HIGH=250
ENERGY_THRESHOLD=0.6
SPEECH_RATE_NORMAL=150

# ============================================================================
# State Inference Configuration
# ============================================================================

STATE_CONFIDENCE_THRESHOLD=0.60
STATE_UNCERTAINTY_THRESHOLD=0.15

WEIGHT_VISUAL=0.6
WEIGHT_AUDIO=0.4

STATE_MEMORY_WINDOW=30

# ============================================================================
# Strategy Selection Configuration
# ============================================================================

STRATEGY_REPETITION_PENALTY=0.1
TIME_ON_TASK_THRESHOLD=600

SLOWDOWN_RATE_MULTIPLIER=0.7
SIMPLIFY_LANGUAGE_REDUCTION=0.5

# ============================================================================
# Dialogue Generation Configuration
# ============================================================================

MAX_DIALOGUE_LENGTH=256
DIALOGUE_TEMPERATURE=0.7

DEFAULT_TONE=encouraging
DEFAULT_SPEAKING_RATE=120

# ============================================================================
# Dataset Configuration
# ============================================================================

MMASD_DATA_PATH=./data/MMASD
MMASD_SPLIT_RATIO=0.8

ANNOTATION_PATH=./data/annotations

# ============================================================================
# Fine-tuning Configuration
# ============================================================================

VLA_MODEL_NAME=openvla-7b

FINETUNING_LEARNING_RATE=1e-4
FINETUNING_BATCH_SIZE=16
FINETUNING_EPOCHS=3
FINETUNING_SAVE_STEPS=100

LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.1

# ============================================================================
# Logging Configuration
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=./logs/teaching_ai.log

LOG_SESSION_INTERACTIONS=True
SESSION_LOG_PATH=./logs/sessions

# ============================================================================
# System Configuration
# ============================================================================

# Device: "cpu" or "cuda"
DEVICE=cuda

VIDEO_FRAME_RATE=30
AUDIO_SAMPLE_RATE=16000

SESSION_TIMEOUT=3600
MAX_INTERACTIONS_PER_SESSION=50

# ============================================================================
# Debugging & Mock Configuration
# ============================================================================

# Use mock LLM instead of real API (for development)
USE_MOCK_LLM=False

# Use mock video/audio input (for testing)
USE_MOCK_INPUT=False

# Verbose logging
VERBOSE=False

# ============================================================================
# Validation & Safety
# ============================================================================

MIN_RESPONSE_CONFIDENCE=0.5

ENABLE_FALLBACK_RESPONSES=True

SAFETY_CHECK_ENABLED=True
